---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import promo from '../data/promo.json';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'posts'> }
const { post } = Astro.props;
const { Content } = await post.render();

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' });

// UTM tagging so Vercel Analytics on creatorkhata.com can attribute which
// blog post + which CTA position (top vs bottom) drove the click.
const utmBase   = `?utm_source=blog&utm_campaign=${encodeURIComponent(post.slug)}`;
const ctaTopUrl = `https://creatorkhata.com/${utmBase}&utm_medium=cta_top`;
const ctaBotUrl = `https://creatorkhata.com/${utmBase}&utm_medium=cta_bottom`;

// Right-side rolling ad rail: the rendered CreatorKhata creatives in public/ads,
// scrolling top -> bottom. The inline banner + card keep the original launch
// promo unchanged — the AI ad creatives live ONLY in this rail.
const ads = (promo.variants ?? []);
const base = import.meta.env.BASE_URL;
const adsBase = (base.endsWith('/') ? base : base + '/') + 'ads/';
const railAds = ads.length ? [...ads, ...ads] : [];
const railUrl = (a: { id: string }) =>
  `https://creatorkhata.com/${utmBase}&utm_medium=ad_rail&utm_content=${encodeURIComponent(a.id)}`;
---
<BaseLayout
  title={`${post.data.title} — CreatorKhata`}
  description={post.data.description}
  ogImage={post.data.ogImage}
>
  <div class="post-layout">
  <article class="post">
    <header class="post-header">
      {post.data.tags[0] && <span class="tag">{post.data.tags[0]}</span>}
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <span>{dateFmt(post.data.pubDate)}</span>
        <span class="dot">·</span>
        <span>{post.data.author}</span>
        {post.data.updatedDate && (
          <>
            <span class="dot">·</span>
            <span>Updated {dateFmt(post.data.updatedDate)}</span>
          </>
        )}
      </div>
    </header>

    <a href={ctaTopUrl} class="about-banner">
      <span class="about-brand">📘 CreatorKhata</span>
      <span class="about-tagline">
        The all-in-one <strong>business app for Indian creators</strong> — GST invoices, brand-deal contracts, payment tracking and rate cards, in one place.
      </span>
      <span class="about-cta">
        <span class="about-action">Try CreatorKhata →</span>
      </span>
    </a>

    <div class="post-body">
      <Content />
    </div>

    <aside class="cta-card">
      <h3>100% free for every Indian creator until 22 Aug 2026.</h3>
      <p>
        GST-ready invoices, contracts, brand-deal pipeline, payment tracking,
        rate cards, outreach — every PRO feature unlocked.
      </p>
      <p style="margin-top:0.75rem;font-size:0.92rem;color:#475569;">
        Bring friends along and keep PRO past August — 3 active referrals = +1 month, 6 = +2, 10 = +3 months free PRO.
      </p>
      <a href={ctaBotUrl} class="btn">Get started — free →</a>
    </aside>
  </article>

  {railAds.length > 0 && (
    <aside class="ad-rail" aria-label="CreatorKhata">
      <span class="ad-rail-label">Featured</span>
      <div class="ad-rail-window">
        <div class="ad-roll">
          {railAds.map((a) => (
            <a href={railUrl(a)} class="ad-slide" target="_blank" rel="noopener">
              <img src={`${adsBase}${a.id}.png`} alt={a.heading} loading="lazy" width="300" height="300" />
            </a>
          ))}
        </div>
      </div>
    </aside>
  )}
  </div>

  <style>
    .post-header { margin-bottom: 1.5rem; }
    .post-header .tag { margin-bottom: 0.75rem; }
    .post-body :global(p:first-of-type) {
      font-size: 1.1rem; color: #1f2330;
    }
    /* Keep embedded screenshots inside the text column (never overflow wide) */
    .post-body :global(img) {
      max-width: 100%; height: auto; display: block;
      margin: 1.75rem auto; border-radius: 10px; border: 1px solid var(--border);
    }
    .about-banner {
      display: flex; flex-direction: column; gap: 0.5rem;
      margin: 0 0 2rem;
      padding: 1.1rem 1.25rem;
      background: linear-gradient(135deg, #eef2ff, #fef3c7);
      border: 1px solid #c7d2fe;
      border-radius: 14px;
      text-decoration: none;
      color: #0f172a;
      line-height: 1.5;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }
    .about-banner:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 22px rgba(15,23,42,0.10);
    }
    .about-brand {
      font-weight: 800; font-size: 1.05rem; letter-spacing: -0.01em; color: #1e1b4b;
    }
    .about-tagline { font-size: 0.97rem; color: #1f2937; }
    .about-cta {
      display: flex; align-items: center; gap: 0.9rem; flex-wrap: wrap;
      margin-top: 0.35rem;
    }
    .about-action {
      font-weight: 700; color: #fff; background: #4f46e5;
      padding: 0.5rem 0.95rem; border-radius: 9px; white-space: nowrap; font-size: 0.92rem;
    }
    .about-banner:hover .about-action { background: #4338ca; }
    @media (max-width: 540px) {
      .about-banner { padding: 0.95rem 1rem; }
      .about-action { width: 100%; text-align: center; }
    }

    /* Rolling ad rail — ALWAYS visible, never alters the text column.
       Default (narrow / normal screens): a centred block BELOW the article.
       Wide screens (>=1300px): pinned to the right gutter, article stays put. */
    .post-layout { display: block; }
    .ad-rail {
      width: 100%; max-width: 300px; margin: 2.75rem auto 0;
      display: flex; flex-direction: column;
    }
    .ad-rail-label {
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
      color: #9ca3af; margin-bottom: 0.6rem; text-align: left;
    }
    .ad-rail-window {
      flex: 1 1 auto; min-height: 0; max-height: 480px; overflow: hidden;
      -webkit-mask-image: linear-gradient(to bottom, transparent, #000 6%, #000 94%, transparent);
      mask-image: linear-gradient(to bottom, transparent, #000 6%, #000 94%, transparent);
    }
    .ad-roll {
      display: flex; flex-direction: column; gap: 1rem;
      animation: adroll 80s linear infinite; will-change: transform;
    }
    .ad-roll:hover { animation-play-state: paused; }
    .ad-slide { display: block; transition: transform 0.15s ease; }
    .ad-slide:hover { transform: scale(1.02); }
    .ad-slide img {
      width: 100%; height: auto; display: block; border-radius: 14px;
      box-shadow: 0 6px 20px rgba(15,23,42,0.10); border: 1px solid #e5e7eb;
    }
    @keyframes adroll { from { transform: translateY(-50%); } to { transform: translateY(0); } }
    @media (prefers-reduced-motion: reduce) { .ad-roll { animation: none; } }

    /* Roomy screens: place the ad to the RIGHT of the article.
       The article keeps its exact 760px width — article + ad centre together as a
       group, so the text column width never changes, it just shifts left a little. */
    @media (min-width: 1024px) {
      .post-layout {
        display: flex; justify-content: center; align-items: flex-start;
        gap: 24px; max-width: 1008px; margin: 0 auto;
      }
      .post-layout .post { flex: 0 0 760px; max-width: 760px; min-width: 0; }
      .ad-rail {
        flex: 0 0 200px; width: 200px; max-width: 200px; margin: 0;
        position: sticky; top: 96px; align-self: flex-start;
        max-height: calc(100vh - 120px);
      }
      .ad-rail-window { max-height: none; }
    }
  </style>

  <style is:global>
    /* Give the page room for the side rail only when wide enough (text stays 760px) */
    @media (min-width: 1024px) {
      .site-main:has(.post-layout) { max-width: 1008px; }
    }
  </style>
</BaseLayout>
